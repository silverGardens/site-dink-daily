---
import BaseLayout from '../layouts/BaseLayout.astro'
import NewsletterForm from '../components/NewsletterForm.astro'
---

<BaseLayout title="Subscribe" description="Get the best pickleball content delivered to your inbox — free.">
  <section class="subscribe-page">
    <div class="subscribe-inner">
      <h1 class="sub-title">Your Daily Pickleball Fix</h1>
      <p class="sub-lead">
        Join pickleball players getting tips, gear reviews, and tournament news — delivered to your inbox.
      </p>
      <ul class="benefits">
        <li><span class="check">✓</span> Skill tips and drills that actually work</li>
        <li><span class="check">✓</span> Honest gear reviews from real players</li>
        <li><span class="check">✓</span> Tournament news and pro coverage</li>
        <li><span class="check">✓</span> Free, forever</li>
      </ul>
      <NewsletterForm variant="standalone" />
      <p class="fine-print">Unsubscribe any time. We respect your inbox.</p>
    </div>
  </section>
</BaseLayout>

<style>
  .subscribe-page {
    padding: 5rem 1.5rem;
    min-height: 80vh;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .subscribe-inner {
    max-width: 480px;
    width: 100%;
    text-align: center;
  }
  .sub-title {
    font-size: clamp(1.75rem, 5vw, 2.5rem);
    font-weight: 800;
    letter-spacing: -0.03em;
    margin-bottom: 1rem;
    line-height: 1.15;
  }
  .sub-lead {
    color: var(--color-muted);
    font-size: 1.0625rem;
    line-height: 1.7;
    margin-bottom: 1.75rem;
  }
  .benefits {
    list-style: none;
    padding: 0;
    margin: 0 0 2rem;
    text-align: left;
  }
  .benefits li {
    display: flex;
    align-items: flex-start;
    gap: 0.625rem;
    padding: 0.4rem 0;
    font-size: 0.9375rem;
    color: var(--color-text);
  }
  .check {
    color: var(--color-accent);
    font-weight: 700;
    flex-shrink: 0;
    margin-top: 0.05rem;
  }
  .fine-print {
    color: var(--color-muted);
    font-size: 0.8125rem;
    margin-top: 1.25rem;
    opacity: 0.7;
  }
</style>
