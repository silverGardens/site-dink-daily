---
import BaseLayout from '../layouts/BaseLayout.astro'
---

<BaseLayout title="Contact" description="Get in touch with the AI Tools Daily team.">
  <section class="contact-page">
    <div class="contact-inner">
      <h1 class="contact-title">Get in Touch</h1>
      <p class="contact-body">
        Have a tool you'd like us to review? A question about our content? A tutorial request? We read everything and reply to as much as we can.
      </p>
      <p class="contact-body">
        The best way to reach us is email. We typically respond within a few business days.
      </p>
      <a href="mailto:hello@aitoolsdaily.com" class="contact-email">hello@aitoolsdaily.com</a>
    </div>
  </section>
</BaseLayout>

<style>
  .contact-page {
    padding: 5rem 1.5rem;
    min-height: 70vh;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .contact-inner { max-width: 540px; width: 100%; text-align: center; }
  .contact-title {
    font-size: clamp(2rem, 5vw, 2.75rem);
    font-weight: 800;
    letter-spacing: -0.03em;
    margin-bottom: 1.5rem;
  }
  .contact-body {
    color: var(--color-muted);
    font-size: 1.0625rem;
    line-height: 1.7;
    margin-bottom: 1rem;
  }
  .contact-email {
    display: inline-block;
    margin-top: 1.25rem;
    color: var(--color-primary);
    font-size: 1.125rem;
    font-weight: 600;
    text-decoration: none;
    padding: 0.75rem 1.75rem;
    border: 1px solid var(--color-primary);
    border-radius: 8px;
    transition: background 0.15s, color 0.15s;
  }
  .contact-email:hover {
    background: var(--color-primary);
    color: #fff;
  }
</style>
