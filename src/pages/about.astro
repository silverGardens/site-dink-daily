---
import BaseLayout from '../layouts/BaseLayout.astro'
import NewsletterForm from '../components/NewsletterForm.astro'
import brand from '../brand.config.json'
---

<BaseLayout title="About" description={`About ${brand.siteName} — ${brand.description}`}>
  <section class="about-hero">
    <div class="about-hero-inner">
      <h1 class="about-title">About {brand.siteName}</h1>
      <p class="about-mission">
        We built Dink Daily for the pickleball player who wants to get better, stay informed, and actually enjoy the journey. The sport is growing fast — and with that comes a lot of noise. Generic tips, gear reviews written by people who've never held a paddle, tournament recaps that miss the story.
      </p>
      <p class="about-mission">
        We do it differently. Our team plays, watches, and talks to players at every level — from recreational kitchen warriors to touring pros. We review gear we've actually tested. We write technique breakdowns that work in real games, not just in theory. Honest coverage of the sport we love.
      </p>
    </div>
  </section>

  <section class="covers-section">
    <div class="covers-inner">
      <h2 class="section-heading">What We Cover</h2>
      <div class="covers-grid">
        <div class="cover-card">
          <div class="cover-icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/></svg>
          </div>
          <h3>Skill Tips</h3>
          <p>Technique breakdowns, strategy guides, and drill recommendations for players who want to improve — tested on real courts.</p>
        </div>
        <div class="cover-card">
          <div class="cover-icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><polygon points="14 2 18 6 7 17 3 17 3 13 14 2"/><line x1="3" y1="22" x2="21" y2="22"/></svg>
          </div>
          <h3>Gear Reviews</h3>
          <p>Honest paddle and equipment reviews from players who've actually played with the gear. What to buy, what to skip, and why.</p>
        </div>
        <div class="cover-card">
          <div class="cover-icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><path d="M19.07 4.93a10 10 0 0 1 0 14.14M4.93 4.93a10 10 0 0 0 0 14.14"/></svg>
          </div>
          <h3>News &amp; Tournaments</h3>
          <p>Pro tour updates, tournament results, rule changes, and what's happening in the fastest-growing sport in America.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="promise-section">
    <div class="promise-inner">
      <h2 class="section-heading">Our Promise</h2>
      <div class="promise-grid">
        <div class="promise-item">
          <div class="promise-num">01</div>
          <h3>Honest Reviews</h3>
          <p>No paid placements, no affiliate bias. We're not paid to like anything. If a tool is overhyped, we'll say so directly.</p>
        </div>
        <div class="promise-item">
          <div class="promise-num">02</div>
          <h3>Real Tutorials</h3>
          <p>Every tutorial we publish has been tested. If a step doesn't work, we debug it before it goes live. No half-baked guides.</p>
        </div>
        <div class="promise-item">
          <div class="promise-num">03</div>
          <h3>Weekly Cadence</h3>
          <p>One email per week, every Tuesday. We don't flood your inbox — just one well-considered piece of content you can actually use.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="about-nl">
    <div class="about-nl-inner">
      <h2>Stay in the loop</h2>
      <p>{brand.tagline} — delivered free every week.</p>
      <NewsletterForm variant="standalone" />
    </div>
  </section>
</BaseLayout>

<style>
  .about-hero {
    padding: 4rem 1.5rem;
    background: radial-gradient(ellipse 70% 50% at 50% 0%, rgba(37,99,235,0.1) 0%, transparent 70%);
    border-bottom: 1px solid rgba(148,163,184,0.08);
  }
  .about-hero-inner { max-width: 720px; margin: 0 auto; }
  .about-title { font-size: clamp(2rem, 5vw, 2.75rem); font-weight: 800; letter-spacing: -0.03em; margin-bottom: 1.5rem; }
  .about-mission { color: var(--color-muted); font-size: 1.0625rem; line-height: 1.75; margin-bottom: 1.25rem; }
  .about-mission:last-child { margin-bottom: 0; }

  .section-heading { font-size: 1.75rem; font-weight: 800; margin-bottom: 2rem; letter-spacing: -0.02em; }

  .covers-section { padding: 4rem 1.5rem; }
  .covers-inner { max-width: 1100px; margin: 0 auto; }
  .covers-grid { display: grid; grid-template-columns: 1fr; gap: 1.5rem; }
  @media (min-width: 768px) { .covers-grid { grid-template-columns: repeat(3,1fr); } }
  .cover-card { background: var(--color-surface); border: 1px solid rgba(148,163,184,0.12); border-radius: 10px; padding: 1.75rem; }
  .cover-icon { width: 48px; height: 48px; background: var(--color-primary-glow); border-radius: 10px; display: flex; align-items: center; justify-content: center; color: var(--color-primary); margin-bottom: 1rem; }
  .cover-card h3 { font-size: 1rem; font-weight: 700; margin-bottom: 0.5rem; }
  .cover-card p { color: var(--color-muted); font-size: 0.9rem; line-height: 1.65; margin: 0; }

  .promise-section { padding: 4rem 1.5rem; background: var(--color-surface); border-top: 1px solid rgba(148,163,184,0.08); }
  .promise-inner { max-width: 1100px; margin: 0 auto; }
  .promise-grid { display: grid; grid-template-columns: 1fr; gap: 1.5rem; }
  @media (min-width: 768px) { .promise-grid { grid-template-columns: repeat(3,1fr); } }
  .promise-item { padding: 0.25rem; }
  .promise-num { font-size: 2rem; font-weight: 800; color: var(--color-primary); opacity: 0.5; margin-bottom: 0.75rem; line-height: 1; }
  .promise-item h3 { font-size: 1.0625rem; font-weight: 700; margin-bottom: 0.5rem; }
  .promise-item p { color: var(--color-muted); font-size: 0.9rem; line-height: 1.65; margin: 0; }

  .about-nl { padding: 4rem 1.5rem; border-top: 1px solid rgba(148,163,184,0.08); }
  .about-nl-inner { max-width: 480px; margin: 0 auto; text-align: center; }
  .about-nl-inner h2 { font-size: 1.5rem; font-weight: 700; margin-bottom: 0.5rem; }
  .about-nl-inner p { color: var(--color-muted); margin-bottom: 1.75rem; }
</style>
