---
import type { CollectionEntry } from 'astro:content'

interface Props {
  post: CollectionEntry<'blog'>
  slug: string
}

const { post, slug } = Astro.props
const { title, description, pubDate, author, heroImage, tags } = post.data

const formattedDate = pubDate.toLocaleDateString('en-US', {
  year: 'numeric', month: 'long', day: 'numeric'
})
---

<article class="blog-card">
  {heroImage ? (
    <img src={heroImage} alt={title} class="card-image" loading="lazy" />
  ) : (
    <div class="card-placeholder"></div>
  )}
  <div class="card-body">
    {tags.length > 0 && (
      <div class="card-tags">
        {tags.slice(0,3).map(tag => (
          <span class="tag">{tag}</span>
        ))}
      </div>
    )}
    <h2 class="card-title">
      <a href={`/blog/${slug}`}>{title}</a>
    </h2>
    <p class="card-desc">{description}</p>
    <div class="card-footer">
      <span class="card-meta">{author} · {formattedDate}</span>
      <a href={`/blog/${slug}`} class="read-more">Read more →</a>
    </div>
  </div>
</article>

<style>
  .blog-card {
    background: var(--color-surface);
    border: 1px solid rgba(148,163,184,0.15);
    border-radius: 10px;
    overflow: hidden;
    transition: border-color 0.2s, transform 0.2s;
    display: flex;
    flex-direction: column;
  }
  .blog-card:hover {
    border-color: var(--color-primary);
    transform: translateY(-2px);
  }
  .card-image {
    width: 100%;
    height: 10rem;
    object-fit: cover;
  }
  .card-placeholder {
    height: 10rem;
    background: linear-gradient(135deg, rgba(37,99,235,0.25), rgba(124,58,237,0.25));
  }
  .card-body {
    padding: 1.25rem;
    display: flex;
    flex-direction: column;
    flex: 1;
  }
  .card-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem;
    margin-bottom: 0.75rem;
  }
  .tag {
    background: rgba(148,163,184,0.12);
    color: var(--color-muted);
    font-size: 0.75rem;
    padding: 0.2rem 0.5rem;
    border-radius: 4px;
    font-weight: 500;
  }
  .card-title {
    font-size: 1.0625rem;
    font-weight: 700;
    line-height: 1.4;
    margin: 0 0 0.625rem;
    letter-spacing: -0.01em;
  }
  .card-title a {
    color: var(--color-text);
    text-decoration: none;
    transition: color 0.15s;
  }
  .card-title a:hover { color: var(--color-primary); }
  .card-desc {
    color: var(--color-muted);
    font-size: 0.9rem;
    line-height: 1.6;
    margin: 0 0 1rem;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    flex: 1;
  }
  .card-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
    flex-wrap: wrap;
    margin-top: auto;
  }
  .card-meta {
    color: var(--color-muted);
    font-size: 0.8125rem;
    opacity: 0.8;
  }
  .read-more {
    color: var(--color-primary);
    font-size: 0.875rem;
    font-weight: 600;
    text-decoration: none;
    white-space: nowrap;
    transition: opacity 0.15s;
  }
  .read-more:hover { opacity: 0.8; }
</style>
