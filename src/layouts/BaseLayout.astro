---
import SEO from '../components/SEO.astro'
import Header from '../components/Header.astro'
import Footer from '../components/Footer.astro'
import brand from '../brand.config.json'

interface Props {
  title: string
  description: string
  image?: string
}
const { title, description, image } = Astro.props

function hexToRgba(hex: string, alpha: number): string {
  const clean = (hex ?? '#000000').replace('#', '').padEnd(6, '0')
  const r = parseInt(clean.slice(0,2), 16) || 0
  const g = parseInt(clean.slice(2,4), 16) || 0
  const b = parseInt(clean.slice(4,6), 16) || 0
  return `rgba(${r},${g},${b},${alpha})`
}

// All CSS custom properties on <html> so every component can use var(--color-*).
const cssVars = [
  `--color-primary:${brand.primaryColor}`,
  `--color-secondary:${brand.secondaryColor}`,
  `--color-accent:${brand.accentColor}`,
  `--color-bg:${brand.backgroundColor}`,
  `--color-surface:${brand.surfaceColor ?? '#1E293B'}`,
  `--color-text:${brand.textColor}`,
  `--color-muted:${brand.mutedColor ?? '#94A3B8'}`,
  // Tinted variants used for gradients, icon bubbles, decorative backgrounds
  `--color-primary-glow:${hexToRgba(brand.primaryColor, 0.15)}`,
  `--color-secondary-glow:${hexToRgba(brand.secondaryColor, 0.18)}`,
  `--color-accent-glow:${hexToRgba(brand.accentColor, 0.12)}`,
  `--font-heading:'${brand.fontHeading}',system-ui,sans-serif`,
  `--font-body:'${brand.fontBody}',system-ui,sans-serif`,
].join(';')

const fonts = [...new Set([brand.fontHeading, brand.fontBody].filter(Boolean))]
const googleFontsUrl = `https://fonts.googleapis.com/css2?${fonts.map(f => `family=${f.replace(/ /g,'+' )}:wght@400;500;600;700;800`).join('&')}&display=swap`
---

<!DOCTYPE html>
<html lang="en" style={cssVars}>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href={googleFontsUrl} rel="stylesheet" />
  {brand.faviconUrl && <link rel="icon" href={brand.faviconUrl} />}
  <SEO title={title} description={description} image={image} />
  <style is:global>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; }
    body {
      background: var(--color-bg);
      color: var(--color-text);
      font-family: var(--font-body);
      line-height: 1.6;
      min-height: 100vh;
      display: flex;
      flex-direction: column;
    }
    main { flex: 1; }
    img { max-width: 100%; height: auto; }
    a { color: inherit; }
    h1, h2, h3, h4, h5, h6 {
      font-family: var(--font-heading);
      line-height: 1.2;
      letter-spacing: -0.02em;
    }
  </style>
</head>
<body>
  <Header />
  <main>
    <slot />
  </main>
  <Footer />
</body>
</html>
